{
  "name": "@guidepup/guidepup",
  "version": "0.27.0",
  "description": "Screen reader automation library for testing.",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "author": "Craig Morten <craig.morten@hotmail.co.uk>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guidepup/guidepup"
  },
  "bugs": {
    "url": "https://github.com/guidepup/guidepup/issues"
  },
  "homepage": "https://github.com/guidepup/guidepup",
  "keywords": [
    "screen reader",
    "screen-reader",
    "accessibility",
    "a11y",
    "voiceover",
    "nvda",
    "guidepup"
  ],
  "scripts": {
    "build": "npm run clean && npm run compile",
    "clean": "rimraf lib",
    "compile": "tsc",
    "lint": "eslint . --ext .ts --cache",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest",
    "test:coverage": "npm run test -- --coverage",
    "prepublish": "npm run build",
    "verify": "npm run clean && npm run lint && npm run test:coverage && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "nock": "^14.0.15",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "regedit": "5.1.2",
    "semver": "^7.3.8"
  }
}
