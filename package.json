{
  "name": "@guidepup/guidepup",
  "version": "0.26.0",
  "description": "Screen reader driver for test automation.",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "author": "Craig Morten <craig.morten@hotmail.co.uk>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guidepup/guidepup"
  },
  "bugs": {
    "url": "https://github.com/guidepup/guidepup/issues"
  },
  "homepage": "https://github.com/guidepup/guidepup",
  "keywords": [
    "screen reader",
    "screen-reader",
    "accessibility",
    "a11y",
    "voiceover",
    "nvda",
    "guidepup"
  ],
  "scripts": {
    "build": "npm run clean && npm run compile",
    "clean": "rimraf lib",
    "compile": "tsc",
    "lint": "eslint . --ext .ts --cache",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest",
    "test:coverage": "npm run test -- --coverage",
    "prepublish": "npm run build",
    "verify": "npm run clean && npm run lint && npm run test:coverage && npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.4.0",
    "nock": "^13.5.5",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "regedit": "5.1.2",
    "semver": "^7.3.8"
  }
}
